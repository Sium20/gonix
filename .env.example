# ─── Gonix — environment variables ──────────────────────────────────────
# Copy to .env (local dev) or set in Vercel → Project → Settings → Environment Variables.
# See README "Supabase + Vercel setup" for the full walkthrough.

# ─── Database (Supabase Postgres) ───────────────────────────────────────
# Get both connection strings from:
#   Supabase Dashboard → your project → Settings → Database → Connection string
#
# DATABASE_URL = Transaction pooler (port 6543) — Vercel serverless runtime + local Prisma queries
# DIRECT_URL   = Direct connection  (port 5432) — Prisma migrations / `prisma db push` / Studio
#
# Replace [PROJECT_REF], [PASSWORD], and [REGION] with your Supabase values.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── NextAuth ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"
# Local dev:
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel — set to your deployment URL or custom domain):
# NEXTAUTH_URL="https://your-domain.com"
# VERCEL="1" is set automatically on Vercel; trustHost: true is enabled in src/lib/auth.ts.

# ─── File storage (Supabase Storage) ───────────────────────────────────
# Create a PRIVATE bucket in Supabase Dashboard → Storage → New bucket.
# Recommended name: "payment-proofs" (or "uploads" if you prefer generic).
STORAGE_BACKEND="supabase"
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."   # server-only — never expose to the client
SUPABASE_STORAGE_BUCKET="payment-proofs"

# ─── Email ──────────────────────────────────────────────────────────────
# Local dev: logs to stdout (default, no env vars needed).
# Production: use Resend (https://resend.com) — no SDK, just the HTTP API.
# EMAIL_BACKEND="resend"
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="Gonix <noreply@your-domain.com>"

# ─── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Gonix"

# ─── Optional: local-only SQLite (NOT for Vercel) ───────────────────────
# If you want to develop against a local SQLite file instead of Supabase,
# comment out the DATABASE_URL above and uncomment this, then flip the
# provider in prisma/schema.prisma back to "sqlite".
# DATABASE_URL="file:./dev.db"
