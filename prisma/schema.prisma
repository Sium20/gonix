// Production target: Supabase Postgres.
// - DATABASE_URL  → Transaction pooler (port 6543) — used by the Vercel serverless runtime
// - DIRECT_URL    → Direct connection  (port 5432) — used by `prisma migrate` for DDL
// Get both from Supabase Dashboard → Project → Settings → Database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Universities & Departments ──────────────────────────────────────────

model University {
  id            String                @id @default(cuid())
  slug          String                @unique
  name          String                @unique // short: "BUET"
  fullName      String? // long: "Bangladesh University of Engineering and Technology"
  type          String // public | private | national | medical | madrasah | other
  division      String?
  city          String?
  website       String?
  domain        String? // "buet.ac.bd" — used for email domain match
  logoUrl       String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  departments   Department[]
  profiles      Profile[]
  verifications VerificationRequest[]

  @@index([isActive])
}

model Department {
  id           String     @id @default(cuid())
  universityId String
  name         String
  code         String?
  isActive     Boolean    @default(true)
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  profiles     Profile[]

  @@unique([universityId, name])
  @@index([universityId])
}

// ─── Profiles (extends NextAuth User concept) ────────────────────────────

model Profile {
  id              String    @id @default(cuid())
  // NextAuth relations
  email           String    @unique
  emailVerified   DateTime?
  passwordHash    String?
  // Profile data
  fullName        String
  handle          String    @unique // URL slug
  role            String // student | teacher | alumni | admin | super_admin
  phone           String?
  universityId    String
  departmentId    String?
  studentId       String? // student ID number (sensitive)
  facultyId       String? // faculty ID number (sensitive)
  designation     String? // for teachers: Lecturer / Asst. Prof. / etc.
  batchYear       Int? // admission year
  graduationYear  Int? // for alumni
  degree          String? // for alumni: B.Sc., M.A., etc.
  currentCompany  String?
  currentTitle    String?
  bio             String?
  avatarUrl       String?
  socialLinks     String? // JSON string
  // Privacy
  showEmail       Boolean   @default(false)
  showPhone       Boolean   @default(false)
  // Status
  status          String    @default("pending") // pending | verified | rejected | suspended
  rejectionReason String?
  verifiedAt      DateTime?
  verifiedById    String?
  lastActiveAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  university          University           @relation(fields: [universityId], references: [id])
  department          Department?          @relation(fields: [departmentId], references: [id])
  verifiedBy          Profile?             @relation("VerifiedBy", fields: [verifiedById], references: [id])
  verifiedProfiles    Profile[]            @relation("VerifiedBy")
  verificationRequest VerificationRequest?
  sessions            Session[]
  accounts            Account[]
  auditLogs           AuditLog[]
  posts               Post[]

  @@index([status])
  @@index([role])
  @@index([universityId])
  @@index([departmentId])
  @@index([batchYear])
}

// ─── NextAuth tables (Account, Session, VerificationToken) ───────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  profile           Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  profile      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Verification Requests ───────────────────────────────────────────────

model VerificationRequest {
  id                 String    @id @default(cuid())
  profileId          String    @unique
  idCardFrontPath    String? // relative to STORAGE_DIR
  idCardBackPath     String?
  supportingDocPath  String? // for alumni
  selfieWithIdPath   String? // optional
  declaredUniversity String?
  declaredIdNumber   String?
  institutionalEmail String?
  emailDomainMatch   Boolean   @default(false)
  // Risk flags
  duplicateIdFlag    Boolean   @default(false)
  lowQualityFlag     Boolean   @default(false)
  vpnFlag            Boolean   @default(false)
  // Decision
  decision           String    @default("pending") // pending | approved | rejected
  decisionNotes      String?
  decidedAt          DateTime?
  decidedById        String?
  ipAddress          String?
  userAgent          String?
  submittedAt        DateTime  @default(now())

  profile      Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  university   University? @relation(fields: [universityId], references: [id])
  universityId String?

  @@index([decision])
  @@index([submittedAt])
}

// ─── Admin Notes & Audit Log ─────────────────────────────────────────────

model AdminNote {
  id        String   @id @default(cuid())
  profileId String
  adminId   String
  note      String
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   String? // JSON string
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor Profile? @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ─── Blog Posts ──────────────────────────────────────────────────────────

model Post {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  slug        String   @unique
  excerpt     String?
  body        String // markdown / plain text
  coverColor  String? // gradient seed e.g. "amber" | "emerald" | "rose" | "indigo" (no image uploads in v1)
  category    String? // "Research" | "Experience" | "Tutorial" | "Announcement" | "Opinion" | free-form
  status      String   @default("published") // published | hidden | flagged
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author Profile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status, publishedAt])
  @@index([authorId])
}
